# ─── Paths ────────────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_BENCHMARK_DIR=data/benchmark

# ─── HuggingFace ──────────────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens adresinden alınır
HF_TOKEN=your_hf_token_here

# ─── Kaggle ───────────────────────────────────────────────────────────────────
# https://www.kaggle.com/settings > API > Create New Token
# Çıkan popup'taki token'ı buraya yapıştır (KGAT_ ile başlar)
KAGGLE_API_TOKEN=your_kaggle_token_here

# ─── WandB (opsiyonel, deney takibi için) ─────────────────────────────────────
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=turkish-legal-rag

# ─── Model Ayarları ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
LLM_MODEL=Qwen/Qwen2.5-3B-Instruct
DEVICE=cuda
